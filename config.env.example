# ── AI News Digest 個人設定範本 ──
# 複製成 config.env 後填入你的值：cp config.env.example config.env
# config.env 已被 .gitignore，不會進版控。
# 注意：這裡「不放密碼」。Gmail App Password 一律存 macOS Keychain。

# 寄件 / 收件信箱（通常相同，寄給自己）
GMAIL_USER="you@gmail.com"
MAIL_TO="you@gmail.com"

# Keychain 內 App Password 的 service 名稱
# 需先執行：security add-generic-password -U -a "你的@gmail.com" -s "ai-news-gmail" -w "16碼AppPassword" -T /usr/bin/security
KEYCHAIN_SERVICE="ai-news-gmail"

# 執行檔路徑（install.sh 會自動偵測填入；也可手動指定）
CLAUDE_BIN="$HOME/.local/bin/claude"
PYTHON_BIN="/opt/homebrew/bin/python3"

# 使用的模型
CLAUDE_MODEL="sonnet"
